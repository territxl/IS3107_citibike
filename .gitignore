# Ignore everything by default — only tracked source files are un-ignored below
*

# Project source files
!.gitignore
!README.md
!requirements.txt

# DAG source code
!dags/
!dags/*.py

# Output data 
!output/
!output/holidays/
!output/holidays/*.csv
!output/citibike_stations/
!output/citibike_stations/*.csv
!output/weather/
!output/weather/*.csv
output/citibike_trips/
output/feature_store/

# Truncated 100-row samples 
!output/samples/
!output/samples/**

# BigQuery ML files
!bigquery-ml/
!bigquery-ml/**

# Streamlit Files
!streamlit-app/
!streamlit-app/**
# except pycache
streamlit-app/**/__pycache__/
streamlit-app/**/*.pyc